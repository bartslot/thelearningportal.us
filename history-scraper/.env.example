# ─── Database ─────────────────────────────────────────────────────────────────
#
# Option A: Supabase  ← RECOMMENDED for production
#   1. Create a free account at https://supabase.com
#   2. New project → Settings → Database → Copy connection string
#   3. Replace [PASSWORD] and [PROJECT-REF] below
#   4. Paste supabase-setup.sql into Supabase SQL Editor and run it ONCE
#
DATABASE_URL=postgresql+asyncpg://postgres:<url-encoded-supabase-db-password>@db.ophofmkxmehmeojvsijc.supabase.co:5432/postgres

# Option B: Local Docker (run `docker compose up -d db` — good for dev)
# DATABASE_URL=postgresql+asyncpg://history:secret@localhost:5432/history_corpus

# Option C: Neon serverless (free tier — alternative to Supabase)
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/history_corpus

# ─── LLM for fact + visual context extraction ─────────────────────────────────
# "ollama"     = free, offline, runs on your machine  ← RECOMMENDED
# "openai"     = any OpenAI-compatible API (LM Studio, vLLM, Groq, Together AI)
# "anthropic"  = Claude Haiku (~$3.50 for full corpus — use only if needed)
LLM_BACKEND=ollama

# Ollama settings (when LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434
LLM_MODEL=gemma3          # pull first: `ollama pull gemma3`
                           # alternatives: gemma:7b  gemma2  llama3.2  mistral

# OpenAI-compatible settings (when LLM_BACKEND=openai)
# LM Studio default: LLM_BASE_URL=http://localhost:1234/v1
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=              # leave blank for local servers; set for Groq/Together

# Anthropic (only needed when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=

# ─── Embeddings for semantic / hybrid vector search ───────────────────────────
#
# "ollama"  = free, offline
#   pull first: `ollama pull nomic-embed-text`
#   produces 768-dim vectors — matches supabase-setup.sql HNSW index
#
# "openai"  = text-embedding-3-small
#   ~$0.30 for full 20K-article corpus
#   produces 1536-dim vectors — update supabase-setup.sql vector() dimension
#
EMBED_BACKEND=ollama
EMBED_MODEL=nomic-embed-text   # 768-dim, fast, excellent retrieval quality
EMBED_DIM=768                  # MUST match the vector() column in supabase-setup.sql

# Set this if EMBED_BACKEND=openai:
OPENAI_API_KEY=

# ─── Scraper tuning ───────────────────────────────────────────────────────────
WHE_RPS=0.5          # 1 request every 2 s for WHE (be polite to their servers)
WIKIPEDIA_RPS=5      # Wikipedia API allows much higher rates

# Max articles to scrape per source per run (0 = no limit)
MAX_ARTICLES=0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
LOG_FILE=scraper.log
