# ==============================================================================
# thelearningportal.us — PRODUCTION .env (SiteGround + Supabase Postgres)
# ==============================================================================
# Copy this to `.env` ON THE SERVER (never commit the real .env — it is gitignored).
# Replace every <FILL_ME> / placeholder with the real value.
# Lines marked  >> SECRET <<  must be filled in by you and never committed.
#
# The production database stays on Supabase Postgres (cloud). There is NO MySQL.
# ==============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=theLearningPortal
APP_ENV=production
APP_KEY=                                   # >> SECRET <<  generate: php artisan key:generate
APP_DEBUG=false
APP_URL=https://thelearningportal.us
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Dev auto-login helpers — MUST be off/removed in production
APP_AUTO_LOGIN=false

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database: APP schema (Supabase Postgres, transaction pooler) ──────────────
# Default connection. Uses the Supabase pooler host on port 5432 (session) or 6543
# (transaction). search_path = app keeps the application tables isolated from the corpus.
DB_CONNECTION=pgsql
DB_HOST=aws-1-us-east-2.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.<PROJECT_REF>         # e.g. postgres.ophofmkxmehmeojvsijc
DB_PASSWORD=                               # >> SECRET <<  Supabase DB password (URL-decoded, quote if it has #/$/% etc.)
DB_SEARCH_PATH=app
DB_SSLMODE=require
# Reuse the TLS connection across Livewire round-trips (pooler handshake is ~1.5s).
DB_PERSISTENT=true

# ── Database: read-only CORPUS schema (Supabase, public schema) ───────────────
# Separate connection name `pgsql_corpus`. Point at the same Supabase pooler.
# Prefer a dedicated SELECT-only Supabase role here.
CORPUS_DB_HOST=aws-1-us-east-2.pooler.supabase.com
CORPUS_DB_PORT=5432
CORPUS_DB_DATABASE=postgres
CORPUS_DB_USERNAME=postgres.<PROJECT_REF>
CORPUS_DB_PASSWORD=                        # >> SECRET <<  corpus DB password (quote if special chars)
# Corpus pooler drops idle connections — keep persistent OFF unless co-located.
CORPUS_DB_PERSISTENT=false

# ── Session / Cache / Queue ───────────────────────────────────────────────────
# Database-backed so they survive SiteGround's PHP-FPM recycling and work without Redis.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.thelearningportal.us
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database

QUEUE_CONNECTION=database
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=660

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Mail (configure a real transport for prod) ────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=<smtp.host>                       # e.g. SiteGround SMTP or a provider
MAIL_PORT=587
MAIL_USERNAME=                              # >> SECRET <<
MAIL_PASSWORD=                              # >> SECRET <<
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@thelearningportal.us"
MAIL_FROM_NAME="${APP_NAME}"

# ── LLM / story generation ────────────────────────────────────────────────────
OPENAI_API_KEY=                            # >> SECRET <<  sk-proj-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_JSON_FORMAT=json_object
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT=60

# Narration (OpenAI TTS)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Anthropic (optional alternate LLM)
ANTHROPIC_API_KEY=                         # >> SECRET <<  sk-ant-...

# ── Image generation / lookup (lesson slideshow backgrounds + skybox) ─────────
OPENAI_API_KEY_IMG=                        # >> SECRET <<  falls back to OPENAI_API_KEY if blank
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_FORMAT=webp

FAL_AI_KEY=                                # >> SECRET <<  fal.ai key (image gen + upscaling)
FAL_IMAGE_MODEL=fal-ai/flux/schnell
FAL_UPSCALE_ENABLED=true

UNSPLASH_ACCESS_KEY=                       # >> SECRET <<
PEXELS_API_KEY=                            # >> SECRET <<
EUROPEANA_API_KEY=                         # >> SECRET <<

# ── Avatar voice / lip-sync (ElevenLabs scheduled warm task + Azure) ──────────
ELEVENLABS_API_KEY=                        # >> SECRET <<
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

AZURE_SPEECH_KEY=                          # >> SECRET <<
AZURE_SPEECH_REGION=eastus

# ── Optional integrations (leave blank unless used in prod) ───────────────────
# WorldLabs splat generation — OFF in prod unless explicitly enabled
WORLD_LABS_API_KEY=                        # >> SECRET <<  (only if WORLD_LABS_ENABLED=true)
WORLD_LABS_ENABLED=false
FAL_KEY=                                   # >> SECRET <<  (WorldLabs path; only if enabled)

# Pocket TTS (local-only — leave blank in prod)
# POCKET_TTS_URL=
# HF_TOKEN=

# ── Lesson settings ───────────────────────────────────────────────────────────
LESSON_STORAGE_DISK=local
MAX_LESSON_GENERATION_ATTEMPTS=3

# Local-only AI service hosts (Ollama / ComfyUI / SadTalker / A1111 / Upscayl /
# fbx2gltf) are intentionally OMITTED — they do not run on SiteGround.
# Production uses the hosted OpenAI / fal.ai / Azure / ElevenLabs APIs above.
