APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Dev auto-login (local only). Set APP_AUTO_LOGIN=true to skip the login page.
# APP_AUTO_LOGIN=false
# APP_USER_ROLE=admin   # admin | teacher | student

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# On Postgres/Supabase: keep app tables in a dedicated schema so migrations never touch the
# read-only history corpus in `public`. REQUIRED in production when DB_CONNECTION=pgsql.
# DB_SEARCH_PATH=app
# Optional: a SELECT-only role for the read-only corpus connection (falls back to DB_* above).
# CORPUS_DB_HOST=
# CORPUS_DB_DATABASE=
# CORPUS_DB_USERNAME=
# CORPUS_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Local AI Services (development) ──────────────────────────────────────────
# Start all with: ./start-local.sh
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

COMFYUI_URL=http://localhost:8188

# ── Production AI APIs (leave blank in local dev) ────────────────────────────
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_SCENE_SIZE=1536x1024
OPENAI_SKYBOX_SIZE=1536x1024
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

ANTHROPIC_API_KEY=

ELEVENLABS_API_KEY=
POCKET_TTS_URL=
HF_TOKEN=

# ── Azure Speech Service (3D avatar lip sync) ────────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ── fal.ai (skybox image upscaler) ───────────────────────────────────────────
FAL_AI_KEY=
FAL_UPSCALE_ENABLED=true
FAL_UPSCALE_MODEL=fal-ai/clarity-upscaler
FAL_UPSCALE_FACTOR=2
FAL_UPSCALE_TIMEOUT=120
FAL_ENHANCE_MODEL=fal-ai/clarity-upscaler
FAL_ENHANCE_FACTOR=4
FAL_SKYBOX_MODEL=fal-ai/flux/dev

# ── Upscayl local CLI (optional) ─────────────────────────────────────────────
UPSCAYL_ENABLED=false
UPSCAYL_BIN=/Applications/Upscayl.app/Contents/Resources/bin/upscayl-bin
UPSCAYL_MODEL_PATH=/Applications/Upscayl.app/Contents/Resources/models
UPSCAYL_MODEL=realesrgan-x4plus

# ── WorldLabs Marble (3D world generation) ────────────────────────────────────
WORLD_LABS_API_KEY=
WORLD_LABS_ENABLED=false

# ── Lesson settings ───────────────────────────────────────────────────────────
LESSON_STORAGE_DISK=local
MAX_LESSON_GENERATION_ATTEMPTS=3


# ── Image search (lesson background slideshow) ────────────────────────────────
# Europeana: free API for European cultural heritage images (primary source)
# Register at: https://pro.europeana.eu/pages/get-api
EUROPEANA_API_KEY=

# Unsplash: photography archive (register at unsplash.com/developers)
UNSPLASH_ACCESS_KEY=

# Pexels: photography archive (register at pexels.com/api)
PEXELS_API_KEY=

# Wikimedia Commons is used as a no-key fallback — no configuration needed.

# ── Vercel serverless functions (avatar studio / audio manifest) ─────────────
VERCEL_FUNCTIONS_URL=http://localhost:3000

# fbx2gltf CLI binary path (install: https://github.com/facebookincubator/FBX2glTF)
FBX2GLTF_BINARY=fbx2gltf
