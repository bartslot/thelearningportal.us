# Tester env template for The Learning Portal.
# Copy to .env for local testing, then fill only the blank secrets.
# Do not commit a filled env file.

APP_NAME="The Learning Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Local tester auto-login
APP_AUTO_LOGIN=true
APP_USER_ROLE=teacher

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
# Use DB_URL if your provider gives one complete connection string.
DB_CONNECTION=pgsql
DB_URL=
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SEARCH_PATH=app
DB_SSLMODE=prefer
DB_PERSISTENT=true

# Optional read-only corpus database. Leave blank to reuse DB_* above.
CORPUS_DB_HOST=
CORPUS_DB_PORT=5432
CORPUS_DB_DATABASE=
CORPUS_DB_USERNAME=
CORPUS_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
MAIL_MAILER=log

# OpenAI
OPENAI_API_KEY=
OPENAI_API_KEY_IMG=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o-mini
OPENAI_JSON_FORMAT=json_object
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_SCENE_SIZE=1536x1024
OPENAI_SKYBOX_SIZE=1536x1024
OPENAI_IMAGE_FORMAT=webp
OPENAI_IMAGE_COMPRESSION=50
OPENAI_IMAGE_STITCH=true
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60
OPENAI_MAX_TOKENS=2048
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# fal.ai
FAL_AI_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/schnell
FAL_SCENE_WIDTH=1024
FAL_SCENE_HEIGHT=512
FAL_SKYBOX_WIDTH=1024
FAL_SKYBOX_HEIGHT=512
FAL_STEPS=4
FAL_TIMEOUT=90
FAL_UPSCALE_ENABLED=true
FAL_UPSCALE_MODEL=fal-ai/clarity-upscaler
FAL_UPSCALE_FACTOR=2
FAL_ENHANCE_MODEL=fal-ai/clarity-upscaler
FAL_ENHANCE_FACTOR=4
FAL_UPSCALE_CONNECT_TIMEOUT=10

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

VITE_APP_NAME="${APP_NAME}"
